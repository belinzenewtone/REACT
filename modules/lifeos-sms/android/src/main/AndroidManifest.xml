<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- SMS permissions — user must grant at runtime (Android 6+) -->
  <uses-permission android:name="android.permission.RECEIVE_SMS" />
  <uses-permission android:name="android.permission.READ_SMS" />

  <!-- Required for WorkManager foreground service (bulk import progress) -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

  <application>
    <!--
      Static receiver registration — fires even when the app process is killed.
      android:permission="android.permission.BROADCAST_SMS" ensures only the
      system telephony stack can trigger this receiver.
      Priority 999 ensures we get the SMS before other receivers.
    -->
    <receiver
      android:name=".SmsReceiver"
      android:enabled="true"
      android:exported="true"
      android:permission="android.permission.BROADCAST_SMS">
      <intent-filter android:priority="999">
        <action android:name="android.provider.Telephony.SMS_RECEIVED" />
      </intent-filter>
    </receiver>
  </application>

</manifest>
