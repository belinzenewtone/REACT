{
  "expo": {
    "name": "PersonalOS",
    "slug": "RFINAL",
    "version": "1.0.50",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#0B0E14",
      "resizeMode": "contain",
      "imageWidth": 200,
      "dark": {
        "image": "./assets/splash-icon.png",
        "backgroundColor": "#0B0E14",
        "resizeMode": "contain",
        "imageWidth": 200
      }
    },
    "userInterfaceStyle": "dark",
    "androidStatusBar": {
      "backgroundColor": "#0B0E14",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#0B0E14"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Used to unlock the app with your fingerprint or face."
      }
    },
    "android": {
      "package": "com.belinze.lifeos",
      "backgroundColor": "#0B0E14",
      "adaptiveIcon": {
        "backgroundColor": "#0B0E14",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_SMS",
        "android.permission.READ_SMS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "LifeOS"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": true
          },
          "ios": {
            "newArchEnabled": true
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "./plugins/withAllowBackup.js",
      "./plugins/withDesugaring.js"
    ],
    "extra": {
      "eas": {
        "projectId": "f7df9ed3-50f4-44bd-9f01-61d89d031c84"
      }
    },
    "owner": "belinze",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f7df9ed3-50f4-44bd-9f01-61d89d031c84"
    }
  }
}
